{
  "name": "myapp",
  "version": "1.0.0",
  "main": "index.html",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux deb"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.yourname.myapp",
    "productName": "MyApp",
    "linux": {
      "target": "deb",
      "category": "Utility"
    },
    "files": ["**/*", "!node_modules"]
  }
}